{
  "name": "retainiq",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @retainiq/db generate",
    "db:migrate": "pnpm --filter @retainiq/db migrate",
    "db:studio": "pnpm --filter @retainiq/db studio",
    "test": "vitest run"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
