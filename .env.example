# Leave unset for embedded PGlite (.data/). Set for Docker / RDS:
# DATABASE_URL=postgresql://retainiq:retainiq@localhost:5432/retainiq

# Shopify Partners app (OAuth + webhook HMAC fallback)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000

# Optional: separate webhook secret (defaults to SHOPIFY_API_SECRET)
SHOPIFY_WEBHOOK_SECRET=

# Comma-separated scopes
SCOPES=read_orders,write_orders

# Post-purchase delayed job (ms). Default 7200000 (2 hours).
# RETAINIQ_POST_PURCHASE_DELAY_MS=7200000
